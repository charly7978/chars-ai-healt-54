{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "verify:all": "npm run lint && npm run type-check && npm run build",
    "audit:simulation": "powershell -Command Get-ChildItem -Recurse -Include *.ts,*.tsx | Select-String -Pattern 'simulate|mock|fake|dummy|demo|Math.random|placeholder|fallback|default.vital|synthetic'",
    "audit:duplicates": "powershell -Command Get-ChildItem -Recurse -Include *.ts | Group-Object Name | Where-Object Count -gt 1",
    "audit:hardcoded": "powershell -Command Get-ChildItem -Recurse -Include *.ts,*.tsx | Select-String -Pattern '120|80|98|99|95|72|70|60|90'",
    "audit:dead-code": "powershell -Command Get-ChildItem -Recurse -Include *.ts,*.tsx | Select-String -Pattern 'unused|dead.code'",
    "audit:all": "echo '=== AUDITORIA FORENSE PPG ===' && npm run audit:simulation && npm run audit:hardcoded",
    "test": "echo 'Forensic validation tests: Run vitest src/tests/ppgForensicValidation.test.ts'",
    "test:unit": "vitest run src/tests/",
    "validate:ppg": "echo 'Validating PPG system integrity...' && npm run type-check && npm run build && npm run audit:all"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.56.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.16.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "lovable-tagger": "^1.1.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1"
  }
}
